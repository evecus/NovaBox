<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_danmu_setting_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 隐藏二维码但保留 ID 供 Java 代码引用，避免 NPE -->
        <ImageView
            android:id="@+id/ivQRCode"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:focusable="false" />

        <!-- 本机地址提示 -->
        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:lineSpacingMultiplier="1.4"
            android:textColor="@color/dialog_text_primary"
            android:textSize="13sp" />

        <!-- 历史直播 / 存储权限 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/apiHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="历史直播"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/storagePermission"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="存储权限"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 点播输入 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="点播"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/input_dialog_api_input"
                android:hint="请输入配置地址"
                android:imeOptions="actionNext|flagNoExtractUi"
                android:inputType="text"
                android:nextFocusDown="@id/inputLive"
                android:nextFocusForward="@id/inputLive"
                android:singleLine="true"
                android:maxLines="1"
                android:paddingLeft="6dp"
                android:paddingTop="8dp"
                android:paddingRight="6dp"
                android:paddingBottom="8dp"
                android:textColor="@color/dialog_text_primary"
                android:textColorHint="@color/dialog_text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/inputSubmit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="选择"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 直播输入 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="直播"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/inputLive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/input_dialog_api_input"
                android:hint="请输入直播地址"
                android:imeOptions="actionDone|flagNoExtractUi"
                android:inputType="text"
                android:nextFocusDown="@id/inputConfirm"
                android:nextFocusForward="@id/inputConfirm"
                android:singleLine="true"
                android:maxLines="1"
                android:paddingLeft="6dp"
                android:paddingTop="8dp"
                android:paddingRight="6dp"
                android:paddingBottom="8dp"
                android:textColor="@color/dialog_text_primary"
                android:textColorHint="@color/dialog_text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/inputSubmitLive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="选择"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 确定按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/inputConfirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_danmu_setting"
                android:focusable="true"
                android:gravity="center"
                android:paddingLeft="24dp"
                android:paddingTop="10dp"
                android:paddingRight="24dp"
                android:paddingBottom="10dp"
                android:text="确定"
                android:textColor="@color/dialog_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
