<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/llLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ===================== Player area (full-width, 16:9) ===================== -->
    <FrameLayout
        android:id="@+id/playerAreaContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:background="@android:color/black"
        android:visibility="gone">

        <!-- Actual player fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/previewPlayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Tap-transparent block: receives first tap to toggle controls -->
        <View
            android:id="@+id/previewPlayerBlock"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:focusable="true"
            android:clickable="true" />

        <!-- Mini controls overlay (shown on tap, auto-hide after 3s) -->
        <LinearLayout
            android:id="@+id/miniControlsOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Top bar: back (left) + lock (right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@android:color/transparent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/miniBackBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/icon_back"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="false"
                    android:contentDescription="返回" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/miniLockBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/icon_unlock"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="false"
                    android:contentDescription="锁定" />
            </LinearLayout>

            <!-- Middle spacer with play/pause center button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/miniPlayPauseBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/icon_pause"
                    android:scaleType="centerInside"
                    android:clickable="true"
                    android:focusable="false"
                    android:background="@android:color/transparent"
                    android:contentDescription="播放/暂停" />
            </FrameLayout>

            <!-- Bottom bar: time + seekbar + fullscreen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@android:color/transparent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/miniCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:minWidth="40dp" />

                <SeekBar
                    android:id="@+id/miniSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:progressTint="@color/color_02F8E1"
                    android:thumbTint="@color/color_02F8E1"
                    android:max="1000" />

                <TextView
                    android:id="@+id/miniTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:minWidth="40dp" />

                <ImageView
                    android:id="@+id/miniFullscreenBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/icon_fullscreen"
                    android:scaleType="centerInside"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="false"
                    android:contentDescription="全屏" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ===================== Scrollable content below player ===================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info card (thumb hidden when player visible, shown when no player) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/infoScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="vertical">

            <LinearLayout
                android:id="@+id/topLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <FrameLayout
                    android:id="@+id/thumbContainer"
                    android:layout_width="100dp"
                    android:layout_height="140dp"
                    android:background="@drawable/shape_detail_thumb_bg">

                    <ImageView
                        android:id="@+id/ivThumb"
                        android:layout_width="96dp"
                        android:layout_height="132dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop" />
                </FrameLayout>

                <!-- Hidden preview player placeholder (compat) -->
                <View
                    android:id="@+id/previewPlayerPlace"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginLeft="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:focusable="false"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:focusable="false"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#CC000000"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:focusable="false"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#CC000000"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvArea"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:focusable="false"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#CC000000"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvLang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:focusable="false"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#CC000000"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#CC000000"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvActor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:focusable="false"
                        android:textColor="#CC000000"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDirector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:focusable="false"
                        android:textColor="#CC000000"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvPlayUrl"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:focusable="false"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:textColor="#CC000000"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <!-- Action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvQuickSearch"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/button_detail_quick_search"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="搜索"
                            android:textColor="@android:color/white"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDesc"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/button_detail_sort"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="简介"
                            android:textColor="@android:color/white"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvCollect"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/button_detail_collect"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="收藏"
                            android:textColor="@android:color/white"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/mEmptyPlaylist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="20dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/icon_empty" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:text="暂无播放数据"
                    android:textColor="@android:color/black"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Flag tab bar -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mGridViewFlag"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true" />

            <!-- Series group row: disabled, no group buttons shown -->
            <LinearLayout
                android:id="@+id/mSeriesGroupTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginRight="12dp"
                android:gravity="center_vertical"
                android:focusable="false"
                android:visibility="gone"
                android:tag="alwaysGone">

                <TextView
                    android:id="@+id/mSeriesSortTv"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/shape_source_series_focus"
                    android:gravity="center"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:text="正序"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:ellipsize="marquee"
                    android:singleLine="true"
                    android:focusable="true"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/mSeriesGroupView"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Episodes grid (fixed height for 4 rows of 3 columns) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mGridView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginRight="12dp"
                android:layout_marginBottom="8dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Preview player block outside scrollview for compat (zero-size) -->
    <View
        android:id="@+id/previewPlayerBlock_compat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:focusable="false"
        android:visibility="gone" />

</LinearLayout>
