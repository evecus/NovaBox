<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 顶部栏：站源切换按钮 + 搜索框 + 收藏 + 历史 -->
    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 站源切换按钮（显示"站源"，点击弹出选源对话框） -->
        <LinearLayout
            android:id="@+id/btnSiteSwitch"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:background="@drawable/shape_source_btn_bg">
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="站源"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginLeft="4dp"
                android:alpha="0.7"
                android:src="@drawable/icon_back"
                android:tint="@android:color/black"
                android:rotation="-90"/>
        </LinearLayout>

        <!-- 搜索框（稍窄，weight 小一些留出云盘图标位置） -->
        <LinearLayout
            android:id="@+id/btnSearch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:background="@drawable/shape_search_bar_bg">
            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:alpha="0.7"
                android:tint="@android:color/black"
                android:src="@drawable/icon_search"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:text="搜索"
                android:textColor="#AA000000"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- OpenList 云盘入口图标 -->
        <ImageView
            android:id="@+id/btnOpenList"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginRight="4dp"
            android:padding="7dp"
            android:src="@drawable/icon_openlist_cloud"
            android:tint="@android:color/black"
            android:alpha="0.85"/>

        <!-- 本地视频入口图标 -->
        <ImageView
            android:id="@+id/btnLocalVideo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginRight="4dp"
            android:padding="7dp"
            android:src="@drawable/icon_local_video"
            android:tint="@android:color/black"
            android:alpha="0.85"/>

        <!-- 收藏图标 -->
        <ImageView
            android:id="@+id/btnCollect"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="7dp"
            android:src="@drawable/icon_collect"
            android:tint="@android:color/black"
            android:alpha="0.85"/>

        <!-- 历史图标 -->
        <ImageView
            android:id="@+id/btnHistory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginLeft="4dp"
            android:padding="7dp"
            android:src="@drawable/icon_history"
            android:tint="@android:color/black"
            android:alpha="0.85"/>

    </LinearLayout>

    <!-- 分类 Tab 横向列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/mGridView"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="2dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:clipToPadding="false"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topLayout"/>

    <!-- 内容 ViewPager -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavLayout"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mGridView">

        <com.mobile.novabox.ui.tv.widget.NoScrollViewPager
            android:id="@+id/mViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@drawable/shape_bottom_nav_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/icon_video"
                android:alpha="1.0" android:tint="#0CADE2"/>
            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="首页"
                android:textColor="#0CADE2"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- 直播 -->
        <LinearLayout
            android:id="@+id/navLive"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/navLiveIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/icon_live"
                android:alpha="0.5" android:tint="@android:color/black"/>
            <TextView
                android:id="@+id/navLiveText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="直播"
                android:textColor="#80000000"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- 设置 -->
        <LinearLayout
            android:id="@+id/navSetting"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/navSettingIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/icon_setting"
                android:alpha="0.5" android:tint="@android:color/black"/>
            <TextView
                android:id="@+id/navSettingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="设置"
                android:textColor="#80000000"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
