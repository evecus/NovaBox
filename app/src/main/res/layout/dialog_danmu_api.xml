<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="@dimen/vs_720"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/shape_danmu_setting_bg"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="@dimen/vs_20"
            android:paddingBottom="@dimen/vs_10"
            android:paddingLeft="@dimen/vs_30"
            android:paddingRight="@dimen/vs_30"
            android:text="弹幕地址"
            android:textColor="@color/dialog_text_primary"
            android:textStyle="bold"
            android:textSize="@dimen/ts_24" />

        <!-- 输入框 -->
        <EditText
            android:id="@+id/input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/vs_30"
            android:layout_marginRight="@dimen/vs_30"
            android:layout_marginBottom="@dimen/vs_10"
            android:background="@drawable/input_dialog_api_input"
            android:imeOptions="actionDone"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingLeft="@dimen/vs_2"
            android:paddingTop="@dimen/vs_10"
            android:paddingRight="@dimen/vs_2"
            android:paddingBottom="@dimen/vs_10"
            android:singleLine="true"
            android:textColor="@color/dialog_text_primary"
            android:textColorHint="@color/dialog_text_hint"
            android:textSize="@dimen/ts_24" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="@color/dialog_panel_stroke" />

        <!-- 取消 / 默认 / 确认 三按钮均分 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/inputCancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="取消"
                android:textColor="#FF333333"
                android:textSize="15sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dialog_panel_stroke" />

            <TextView
                android:id="@+id/inputDefault"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="默认"
                android:textColor="@color/dialog_text_primary"
                android:textSize="15sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dialog_panel_stroke" />

            <TextView
                android:id="@+id/inputSubmit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="确认"
                android:textColor="@color/dialog_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
