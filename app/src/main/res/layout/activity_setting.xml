<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 设置内容区域 -->
    <com.mobile.novabox.ui.tv.widget.NoScrollViewPager
        android:id="@+id/mViewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavLayout"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <!-- 底部导航栏（与首页一致） -->
    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@drawable/shape_bottom_nav_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/icon_video"
                android:alpha="0.5" android:tint="@android:color/black"/>
            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="首页"
                android:textColor="#80000000"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- 直播 -->
        <LinearLayout
            android:id="@+id/navLive"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/navLiveIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/icon_live"
                android:alpha="0.5" android:tint="@android:color/black"/>
            <TextView
                android:id="@+id/navLiveText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="直播"
                android:textColor="#80000000"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- 设置（当前页，高亮） -->
        <LinearLayout
            android:id="@+id/navSetting"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/navSettingIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/icon_setting"
                android:alpha="1.0" android:tint="#0CADE2"/>
            <TextView
                android:id="@+id/navSettingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="设置"
                android:textColor="#0CADE2"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
