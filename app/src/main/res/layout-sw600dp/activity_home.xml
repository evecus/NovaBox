<?xml version="1.0" encoding="utf-8"?>
<!--
    Pad 端首页布局（sw600dp）
    改动要点：
      - 底部导航栏 → 左侧竖向导航栏（72dp 宽），更符合横屏习惯
      - 顶部栏高度从 56dp 提高到 64dp，搜索框更宽
      - 分类 Tab 改为竖向放在左侧栏内部，内容区域获得更大横向空间
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════════════════════════════
         左侧导航栏（竖向，宽 72dp）
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="72dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/shape_side_nav_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/selector_nav_item_bg">
            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_video"
                android:alpha="1.0" android:tint="#0CADE2"/>
            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="首页"
                android:textColor="#0CADE2"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- 直播 -->
        <LinearLayout
            android:id="@+id/navLive"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/selector_nav_item_bg">
            <ImageView
                android:id="@+id/navLiveIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_live"
                android:alpha="0.5" android:tint="@android:color/black"/>
            <TextView
                android:id="@+id/navLiveText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="直播"
                android:textColor="#80000000"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- 设置 -->
        <LinearLayout
            android:id="@+id/navSetting"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/selector_nav_item_bg">
            <ImageView
                android:id="@+id/navSettingIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_setting"
                android:alpha="0.5" android:tint="@android:color/black"/>
            <TextView
                android:id="@+id/navSettingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="设置"
                android:textColor="#80000000"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         右侧主内容区
         ═══════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/bottomNavLayout"
        app:layout_constraintRight_toRightOf="parent">

        <!-- 顶部栏：站源切换 + 搜索框 + 收藏 + 历史 -->
        <LinearLayout
            android:id="@+id/topLayout"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 站源切换按钮 -->
            <LinearLayout
                android:id="@+id/btnSiteSwitch"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:background="@drawable/shape_source_btn_bg">
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="站源"
                    android:textColor="@android:color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginLeft="4dp"
                    android:alpha="0.7"
                    android:src="@drawable/icon_back"
                    android:tint="@android:color/black"
                    android:rotation="-90"/>
            </LinearLayout>

            <!-- 搜索框（弹性占满剩余空间） -->
            <LinearLayout
                android:id="@+id/btnSearch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:background="@drawable/shape_search_bar_bg">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:alpha="0.7"
                    android:tint="@android:color/black"
                    android:src="@drawable/icon_search"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="搜索影视..."
                    android:textColor="#AA000000"
                    android:textSize="15sp"/>
            </LinearLayout>

            <!-- OpenList 云盘入口图标 -->
            <ImageView
                android:id="@+id/btnOpenList"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginRight="6dp"
                android:padding="8dp"
                android:src="@drawable/icon_openlist_cloud"
                android:tint="@android:color/black"
                android:alpha="0.85"/>

            <!-- 本地视频入口图标 -->
            <ImageView
                android:id="@+id/btnLocalVideo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginRight="6dp"
                android:padding="8dp"
                android:src="@drawable/icon_local_video"
                android:tint="@android:color/black"
                android:alpha="0.85"/>

            <!-- 收藏图标 -->
            <ImageView
                android:id="@+id/btnCollect"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/icon_collect"
                android:tint="@android:color/black"
                android:alpha="0.85"/>

            <!-- 历史图标 -->
            <ImageView
                android:id="@+id/btnHistory"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginLeft="6dp"
                android:padding="8dp"
                android:src="@drawable/icon_history"
                android:tint="@android:color/black"
                android:alpha="0.85"/>

        </LinearLayout>

        <!-- 分类 Tab 横向列表（高度略大以方便点击） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mGridView"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="2dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:clipToPadding="false"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/topLayout"/>

        <!-- 内容 ViewPager（占满剩余空间） -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mGridView">

            <com.mobile.novabox.ui.tv.widget.NoScrollViewPager
                android:id="@+id/mViewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
