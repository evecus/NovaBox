<?xml version="1.0" encoding="utf-8"?>
<!-- 平板端：左侧播放器 右侧标题+列表 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- 左侧播放器区域 (约74%，参考哔哩哔哩比例) -->
    <FrameLayout
        android:id="@+id/flPlayerContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="74"
        android:background="#FF000000">

        <com.mobile.novabox.player.MyVideoView
            android:id="@+id/mVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- 控制层 -->
        <FrameLayout
            android:id="@+id/flControlOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#44000000"
            android:visibility="gone">

            <!-- 返回按钮 -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:padding="8dp"
                android:src="@drawable/icon_back"
                android:tint="@android:color/white"
                android:scaleType="fitCenter"/>

            <!-- 锁屏按钮 -->
            <ImageView
                android:id="@+id/ivLock"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:padding="8dp"
                android:src="@drawable/icon_unlock"
                android:tint="@android:color/white"
                android:scaleType="fitCenter"/>

            <!-- 中央播放/暂停 -->
            <ImageView
                android:id="@+id/ivPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:padding="8dp"
                android:src="@drawable/icon_pause"
                android:tint="@android:color/white"
                android:scaleType="fitCenter"/>

            <!-- 底部进度条区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvCurrentPos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:max="1000"
                    android:progressTint="@android:color/white"
                    android:thumbTint="@android:color/white"/>

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"/>

                <!-- 全屏按钮 -->
                <ImageView
                    android:id="@+id/ivFullscreen"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="10dp"
                    android:padding="7dp"
                    android:src="@drawable/icon_fullscreen"
                    android:tint="@android:color/white"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

            <!-- 缓冲转圈 -->
            <ProgressBar
                android:id="@+id/pbLoading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"/>

        </FrameLayout>
    </FrameLayout>

    <!-- 右侧：标题 + 播放列表 (约26%，参考哔哩哔哩比例) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="26"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/icon_back"
                android:tint="@android:color/black"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvVideoTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:textColor="@android:color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20000000"/>

        <!-- 播放列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"/>

    </LinearLayout>

</LinearLayout>
